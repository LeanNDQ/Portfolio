---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import TechStack from '../components/sections/TechStack.astro';
import Projects from '../components/sections/Projects.astro';
import Contact from '../components/sections/Contact.astro';
import Footer from '../components/layout/Footer.astro';
import { siteData } from '../data/site';

const seo = siteData.seo ?? {
	title: 'Leandro Diaz Quinteros | Portafolio',
	description:
		'Portafolio profesional de Leandro Diaz Quinteros, estudiante de Desarrollo de Software.',
};
---

<Layout title={seo.title} description={seo.description}>
	<Header />
	<main id="contenido" class="page-main">
		<Hero />
		<About />
		<TechStack />
		<Projects />
		<Contact />
	</main>
	<Footer />
</Layout>
