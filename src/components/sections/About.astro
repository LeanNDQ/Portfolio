---
import { siteData } from '../../data/site';
import SectionHeading from '../ui/SectionHeading.astro';

const about = siteData.about ?? {
  title: 'Sobre mi',
  subtitle: 'Construyendo una base tecnica solida con foco en aprendizaje y crecimiento.',
  items: [],
};
const aboutTitle = about.title ?? 'Sobre mi';
const aboutSubtitle =
  about.subtitle ?? 'Construyendo una base tecnica solida con foco en aprendizaje y crecimiento.';
const aboutItems = about.items ?? [];
---

<section id="sobre-mi" class="section reveal" data-reveal>
  <div class="section-inner">
    <SectionHeading title={aboutTitle} subtitle={aboutSubtitle} />
    <div class="grid gap-6 md:grid-cols-2">
      {aboutItems.map((item) => (
        <article class="glass rounded-2xl border border-white/10 p-6">
          <h3 class="text-lg font-semibold text-white">{item.title ?? 'Formacion'}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-300">
            {item.description ?? 'Contenido pendiente de completar.'}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
