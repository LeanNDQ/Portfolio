---
import type { DeepPartial, Project, ProjectStatus } from '../../types/site';
import StatusPill from './StatusPill.astro';

type Props = {
  project: DeepPartial<Project>;
};

const { project } = Astro.props as Props;
const title = project.title ?? 'Proyecto en desarrollo';
const description = project.description ?? 'Descripcion pendiente de completar.';
const status = (project.status ?? 'En progreso') as ProjectStatus;
const tag = project.tag ?? 'Proyecto';
const timeline = project.timeline ?? '2026';
const role = project.role ?? 'Full-stack';
const logo = project.logo;
const cta = project.cta;
const preview = project.preview;
const previewLabel = project.previewLabel ?? 'Ver muestra';
const info = project.info;
const infoTitle = project.infoTitle ?? 'Mas info';
const dialogId = project.id ? `preview-${project.id}` : undefined;
const infoDialogId = project.id ? `info-${project.id}` : undefined;
---

<article class="glass flex h-full flex-col rounded-2xl border border-white/10 p-6">
  {logo?.src && (
    <div class="project-logo project-logo--hero">
      <img src={logo.src} alt={logo.alt ?? title} loading="lazy" />
    </div>
  )}
  <div class={logo?.src ? 'mt-5' : ''}>
    <span class="text-xs uppercase tracking-[0.3em] text-slate-400">{tag}</span>
    <h3 class="mt-4 text-lg font-semibold text-white">{title}</h3>
  </div>
  <div class="mt-3 flex flex-wrap items-center gap-2">
    <StatusPill status={status} />
    <span class="text-xs uppercase tracking-[0.25em] text-slate-400">Rol: {role}</span>
  </div>
  <p class="mt-3 text-sm leading-7 text-slate-300">{description}</p>
  <div class="mt-auto pt-6">
    <div class="flex flex-wrap items-center gap-3">
      <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-2 text-xs text-slate-300">
        <span class="h-2 w-2 rounded-full bg-white/40"></span>
        Periodo: {timeline}
      </div>
      {cta?.href && (
        <a
          class="project-cta"
          href={cta.href}
          target={cta.external ? '_blank' : undefined}
          rel={cta.external ? 'noreferrer' : undefined}
        >
          {cta.label ?? 'Ver sitio'}
        </a>
      )}
      {preview?.src && dialogId && (
        <button
          class="project-cta"
          type="button"
          onclick={`document.getElementById('${dialogId}')?.showModal()`}
        >
          {previewLabel}
        </button>
      )}
      {info && info.length > 0 && infoDialogId && (
        <button
          class="project-cta"
          type="button"
          onclick={`document.getElementById('${infoDialogId}')?.showModal()`}
        >
          Mas info
        </button>
      )}
    </div>
  </div>
  {preview?.src && dialogId && (
    <dialog id={dialogId} class="project-dialog">
      <div class="project-dialog-header">
        <span class="project-dialog-title">{title}</span>
        <form method="dialog">
          <button class="project-dialog-close" aria-label="Cerrar muestra">
            Cerrar
          </button>
        </form>
      </div>
      <div class="project-dialog-body">
        <img src={preview.src} alt={preview.alt ?? `Muestra de ${title}`} loading="lazy" />
      </div>
    </dialog>
  )}
  {info && info.length > 0 && infoDialogId && (
    <dialog id={infoDialogId} class="project-dialog">
      <div class="project-dialog-header">
        <span class="project-dialog-title">{infoTitle}</span>
        <form method="dialog">
          <button class="project-dialog-close" aria-label="Cerrar informacion">
            Cerrar
          </button>
        </form>
      </div>
      <div class="project-dialog-body project-dialog-body--text">
        {logo?.src && (
          <div class="project-logo project-logo--hero">
            <img src={logo.src} alt={logo.alt ?? title} loading="lazy" />
          </div>
        )}
        <h4 class="project-info-title">{title}</h4>
        <ul class="project-info-list">
          {info.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </dialog>
  )}
</article>
