---
import type { ProjectStatus } from '../../types/site';

type Props = {
  status: ProjectStatus;
};

const { status } = Astro.props as Props;

const styles: Record<string, string> = {
  Terminado: 'bg-slate-800 text-slate-200',
  'En progreso': 'bg-emerald-500/15 text-emerald-200',
  Investigando: 'bg-amber-500/15 text-amber-200',
};
---

<span class={`rounded-full px-3 py-1 text-xs font-semibold ${styles[status] ?? 'bg-slate-800 text-slate-200'}`}>{status}</span>
