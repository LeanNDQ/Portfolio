---
type Props = {
  title: string;
  subtitle?: string;
  eyebrow?: string;
};

const { title, subtitle, eyebrow } = Astro.props as Props;
---

<div class="mb-10">
  {eyebrow ? (
    <p class="text-xs uppercase tracking-[0.3em] text-brand-100/70">{eyebrow}</p>
  ) : null}
  <h2 class="mt-4 text-3xl font-semibold text-white sm:text-4xl">{title}</h2>
  {subtitle ? (
    <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-300">{subtitle}</p>
  ) : null}
</div>
